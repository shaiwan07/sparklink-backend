          },
          "responses": {
            "200": {
              "description": "Video call scheduled",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/SuccessResponse" }
                }
              }
            },
            "400": {
              "description": "match_id and scheduled_time required",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                }
