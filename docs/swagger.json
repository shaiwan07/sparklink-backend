{
  "openapi": "3.0.0",
  "info": {
    "title": "Sparklink Dating API",
    "description": "Smart Links, Real Connections — Full API for the Sparklink mobile application",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://139.59.17.235:5000",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Slot": {
        "type": "object",
        "required": [
          "day_of_week",
          "start_time",
          "end_time"
        ],
        "properties": {
          "day_of_week": {
            "type": "string",
            "enum": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri",
              "Sat",
              "Sun"
            ]
          },
          "start_time": {
            "type": "string",
            "example": "09:00:00"
          },
          "end_time": {
            "type": "string",
            "example": "12:00:00"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Registration, login, OTP, password reset"
    },
    {
      "name": "Profile",
      "description": "User profile management"
    },
    {
      "name": "Interests",
      "description": "Interest tags"
    },
    {
      "name": "Questionnaire",
      "description": "25-question compatibility questionnaire"
    },
    {
      "name": "Matches",
      "description": "Swiping, matching, potential matches"
    },
    {
      "name": "Availability",
      "description": "User availability for video call scheduling"
    },
    {
      "name": "Video Calls",
      "description": "Schedule and manage video dates"
    },
    {
      "name": "Gap Report",
      "description": "Compatibility analysis between matched users"
    },
    {
      "name": "Notifications",
      "description": "In-app notifications"
    },
    {
      "name": "Rewards",
      "description": "Sparklink Club rewards and QR offers"
    },
    {
      "name": "Report",
      "description": "Report harassment"
    },
    {
      "name": "Account",
      "description": "Account settings and deletion"
    },
    {
      "name": "Users",
      "description": "Public user profile endpoints"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register with email and password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "confirmPassword"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered. OTP sent to email."
          },
          "409": {
            "description": "Email already registered"
          }
        }
      }
    },
    "/auth/verify-email": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Verify email OTP — screen 07",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "otp"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "otp": {
                    "type": "string",
                    "example": "482910"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verified. Returns JWT + user."
          },
          "401": {
            "description": "Invalid or expired OTP"
          }
        }
      }
    },
    "/auth/resend-otp": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Resend verification OTP — screen 07 countdown reset",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP resent"
          },
          "400": {
            "description": "Email already verified"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login with email and password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login OK. Returns JWT + user."
          },
          "401": {
            "description": "Invalid credentials"
          },
          "403": {
            "description": "Email not verified"
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Request password reset OTP — screen 08",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent to email"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Logout — screen 48 (client discards JWT)",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/api/profile": {
      "get": {
        "tags": [
          "Profile"
        ],
        "summary": "Get current user full profile (photos, interests, location, preferences)",
        "responses": {
          "200": {
            "description": "Full profile object"
          }
        }
      },
      "put": {
        "tags": [
          "Profile"
        ],
        "summary": "Update profile — all onboarding + edit profile fields — screen 49",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "full_name": {
                    "type": "string"
                  },
                  "age": {
                    "type": "integer"
                  },
                  "height": {
                    "type": "integer",
                    "description": "Height in cm (Preferences screen step 3)"
                  },
                  "gender": {
                    "type": "string",
                    "enum": [
                      "male",
                      "female",
                      "other"
                    ]
                  },
                  "phone": {
                    "type": "string"
                  },
                  "instagram_username": {
                    "type": "string"
                  },
                  "bio": {
                    "type": "string"
                  },
                  "language": {
                    "type": "string"
                  },
                  "current_step": {
                    "type": "integer",
                    "description": "Onboarding step 1-6"
                  },
                  "city": {
                    "type": "string"
                  },
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  },
                  "interested_in": {
                    "type": "string",
                    "enum": [
                      "male",
                      "female",
                      "other",
                      "all"
                    ]
                  },
                  "min_age": {
                    "type": "integer"
                  },
                  "max_age": {
                    "type": "integer"
                  },
                  "max_distance_km": {
                    "type": "integer"
                  },
                  "interests": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of interest_id values"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          }
        }
      }
    },
    "/api/profile/photo": {
      "post": {
        "tags": [
          "Profile"
        ],
        "summary": "Upload up to 5 profile photos — screens 11-12 (multipart/form-data)",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    },
                    "maxItems": 5
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photos uploaded. Returns array of URLs."
          },
          "400": {
            "description": "No files uploaded"
          }
        }
      }
    },
    "/api/profile/photo/{photoId}": {
      "delete": {
        "tags": [
          "Profile"
        ],
        "summary": "Delete a profile photo — screen 49",
        "parameters": [
          {
            "name": "photoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Photo deleted"
          }
        }
      }
    },
    "/api/interests": {
      "get": {
        "tags": [
          "Interests"
        ],
        "summary": "Get all interest tags with icons — screen 16 (public)",
        "security": [],
        "responses": {
          "200": {
            "description": "List with interest_id, name, icon_url"
          }
        }
      }
    },
    "/api/questions": {
      "get": {
        "tags": [
          "Questionnaire"
        ],
        "summary": "Get all 25 questions with category and options — screens 18-42 (public)",
        "security": [],
        "responses": {
          "200": {
            "description": "Questions array — each has question_id, text, type, category_name, options[]"
          }
        }
      }
    },
    "/api/questionnaire": {
      "post": {
        "tags": [
          "Questionnaire"
        ],
        "summary": "Submit questionnaire answers",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "answers"
                ],
                "properties": {
                  "answers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "question_id": {
                          "type": "integer"
                        },
                        "option_id": {
                          "type": "integer",
                          "description": "For single_choice questions"
                        },
                        "answer": {
                          "type": "string",
                          "description": "For scale questions — numeric string e.g. \"3\""
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answers saved (upserted per question)"
          },
          "400": {
            "description": "No answers provided"
          }
        }
      }
    },
    "/api/questionnaire/{userId}": {
      "get": {
        "tags": [
          "Questionnaire"
        ],
        "summary": "Get a user answers",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User answers with question text and option text"
          }
        }
      }
    },
    "/api/matches": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "Get all confirmed matches for current user",
        "responses": {
          "200": {
            "description": "Matches list — each includes match_id, matched_user_id"
          }
        }
      }
    },
    "/api/matches/potential": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "Get potential matches filtered by preferences + distance + compatibility % — screen 44",
        "responses": {
          "200": {
            "description": "Candidates sorted by match_percentage desc — each has distance_km, match_percentage, photos[]"
          },
          "400": {
            "description": "Profile/preferences/location incomplete"
          }
        }
      }
    },
    "/api/matches/like": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Like a user — swipe right (writes to swipes table, auto-creates match if mutual)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_id"
                ],
                "properties": {
                  "user_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "result: \"liked\" or \"matched\""
          }
        }
      }
    },
    "/api/matches/superlike": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Superlike a user (writes to swipes table, auto-creates match if mutual)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_id"
                ],
                "properties": {
                  "user_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "result: \"superliked\" or \"matched\""
          }
        }
      }
    },
    "/api/matches/dislike": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Dislike a user — swipe left",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_id"
                ],
                "properties": {
                  "user_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disliked"
          }
        }
      }
    },
    "/api/matches/unmatch": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Unmatch — sets status to unmatched",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "match_id"
                ],
                "properties": {
                  "match_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unmatched"
          },
          "403": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/matches/block": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Block a matched user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "match_id"
                ],
                "properties": {
                  "match_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Blocked"
          },
          "403": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/matches/{matchId}/profile": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "Full profile of matched user with compatibility analysis — screens 50-51",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "user + photos + interests + match_percentage + gap_report + match_reasons"
          },
          "403": {
            "description": "Not your match"
          }
        }
      }
    },
    "/api/matches/{matchId}/contact": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "Get phone and Instagram of matched user — screen 55 (It is a Match!)",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "{ phone, instagram_username }"
          },
          "403": {
            "description": "Not your match"
          }
        }
      }
    },
    "/api/availability": {
      "get": {
        "tags": [
          "Availability"
        ],
        "summary": "Get my availability slots — screen 52",
        "responses": {
          "200": {
            "description": "Array of { id, day_of_week, start_time, end_time }"
          }
        }
      },
      "post": {
        "tags": [
          "Availability"
        ],
        "summary": "Set my availability — screen 52 (replaces all existing slots)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "slots"
                ],
                "properties": {
                  "slots": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Slot"
                    }
                  }
                }
              },
              "example": {
                "slots": [
                  {
                    "day_of_week": "Mon",
                    "start_time": "09:00:00",
                    "end_time": "12:00:00"
                  },
                  {
                    "day_of_week": "Mon",
                    "start_time": "14:00:00",
                    "end_time": "18:00:00"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Availability updated"
          },
          "400": {
            "description": "Invalid slot format"
          }
        }
      }
    },
    "/api/availability/overlap/{matchId}": {
      "get": {
        "tags": [
          "Availability"
        ],
        "summary": "Get overlapping time slots with a match — screens 52-53. Add ?day=Mon to filter by day.",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "day",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Mon",
                "Tue",
                "Wed",
                "Thu",
                "Fri",
                "Sat",
                "Sun"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of { overlap_start, overlap_end }. Empty = screen 53 no-overlap state."
          },
          "403": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/availability/{userId}": {
      "get": {
        "tags": [
          "Availability"
        ],
        "summary": "Get a matched user availability — screen 52 match side",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Match slots"
          },
          "403": {
            "description": "Not a match — access denied"
          }
        }
      }
    },
    "/api/video-calls": {
      "post": {
        "tags": [
          "Video Calls"
        ],
        "summary": "Schedule a video call — screen 52 (Schedule Call button)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "match_id"
                ],
                "properties": {
                  "match_id": {
                    "type": "integer",
                    "example": 100
                  },
                  "scheduled_time": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-04-20T10:00:00",
                    "description": "Optional — omit for an immediate call"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call created — returns Agora channel info for both users to join",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Video call ready",
                  "data": [
                    {
                      "call_id": 5,
                      "channelName": "call_100_1713456789123",
                      "rtcToken": "006a6bda22cec214e9f...signed_token...",
                      "uid": 10,
                      "appId": "a6bda22cec214e9f92bd1621a8a9058c"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Video Calls"
        ],
        "summary": "Get all my video calls — screen 45 Alerts tab",
        "responses": {
          "200": {
            "description": "Video calls with match info"
          }
        }
      }
    },
    "/api/video-calls/status": {
      "post": {
        "tags": [
          "Video Calls"
        ],
        "summary": "Update call status (scheduled / completed / cancelled / failed)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "call_id",
                  "status"
                ],
                "properties": {
                  "call_id": {
                    "type": "integer"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "scheduled",
                      "completed",
                      "cancelled",
                      "failed"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated"
          }
        }
      }
    },
    "/api/video-calls/{match_id}": {
      "get": {
        "tags": [
          "Video Calls"
        ],
        "summary": "Get scheduled call for a specific match",
        "parameters": [
          {
            "name": "match_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Call details"
          },
          "404": {
            "description": "No call found"
          }
        }
      }
    },
    "/api/video-calls/{callId}/feedback": {
      "post": {
        "tags": [
          "Video Calls"
        ],
        "summary": "Post-call feedback — screen 56 (Love it / Not a Match buttons)",
        "parameters": [
          {
            "name": "callId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "feedback"
                ],
                "properties": {
                  "feedback": {
                    "type": "string",
                    "enum": [
                      "love_it",
                      "not_a_match"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback recorded. not_a_match also unmatches the two users."
          },
          "403": {
            "description": "Not authorized"
          },
          "404": {
            "description": "Call not found"
          }
        }
      }
    },
