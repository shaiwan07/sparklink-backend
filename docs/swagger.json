  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
        "VideoCall": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "match_id": { "type": "integer" },
            "scheduled_time": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
            "created_at": { "type": "string", "format": "date-time" },
            "user1_id": { "type": "integer" },
            "user2_id": { "type": "integer" }
          }
        },
        "Reward": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "discount_percent": { "type": "integer" },
            "qr_code_url": { "type": "string" },
            "expiration_date": { "type": "string", "format": "date" }
          }
        },
        "UserOffer": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "user_id": { "type": "integer" },
            "offer_id": { "type": "integer" },
            "redeemed_at": { "type": "string", "format": "date-time" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "discount_percent": { "type": "integer" },
            "qr_code_url": { "type": "string" },
            "expiration_date": { "type": "string", "format": "date" }
          }
        },
        "Notification": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "user_id": { "type": "integer" },
            "type": { "type": "string", "enum": ["match", "alert", "meeting", "reward"] },
            "message": { "type": "string" },
            "is_read": { "type": "boolean" },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "Match": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "user1_id": { "type": "integer" },
            "user2_id": { "type": "integer" },
            "status": { "type": "string", "enum": ["pending", "matched", "unmatched", "blocked"] },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "Question": {
          "type": "object",
          "properties": {
            "id": { "type": "integer" },
            "text": { "type": "string" },
            "type": { "type": "string", "enum": ["single_choice", "scale", "text"] }
          }
        },
        "QuestionnaireAnswer": {
          "type": "object",
          "properties": {
            "question_id": { "type": "integer" },
            "text": { "type": "string" },
            "type": { "type": "string" },
            "answer": { "type": "string" }
          }
        },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string" },
          "phone_number": { "type": "string" },
          "full_name": { "type": "string" },
          "age": { "type": "integer" },
          "gender": { "type": "string" },
          "city": { "type": "string" },
          "bio": { "type": "string" },
          "profile_photo_url": { "type": "string" },
          "language": { "type": "string" },
          "is_verified": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "UserPhoto": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "photo_url": { "type": "string" }
        }
      },
      "Interest": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "icon_url": { "type": "string", "description": "URL of the interest icon" }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "latitude": { "type": "number" },
          "longitude": { "type": "number" }
        }
      },
      "Preference": {
        "type": "object",
        "properties": {
          "interested_in": { "type": "string" },
          "min_age": { "type": "integer" },
          "max_age": { "type": "integer" },
          "min_height": { "type": "integer" },
          "max_height": { "type": "integer" },
          "max_distance_km": { "type": "integer" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "Password@123"
          },
          "confirmPassword": {
            "type": "string",
            "format": "password",
            "example": "Password@123"
          }
        },
        "required": ["email", "password", "confirmPassword"]
      },
      "VerifyEmailRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "otp": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["email", "otp"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        },
        "required": ["email", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Login successful"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation successful"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Something went wrong"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}