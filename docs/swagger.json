                      "status": { "type": "boolean" },
                      "message": { "type": "string" },
                      "data": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/VideoCall" }
                      }
                    }
                  }
                }
              }
            },
            "500": {
              "description": "Server error",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                }
              }
            }
