      "/api/questionnaire": {
        "post": {
          "summary": "Submit questionnaire answers",
          "tags": ["Questionnaire"],
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "answers": {
                      "type": "array",
                      "items": {
                        "type": "object",
