    "/api/profile": {
      "get": {
        "summary": "Get user profile (all info, interests, preferences, location, photos)",
        "tags": ["Profile"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Profile fetched",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "profile": {
                      "type": "object",
                      "properties": {
                        "user": { "$ref": "#/components/schemas/User" },
                        "interests": { "type": "array", "items": { "$ref": "#/components/schemas/Interest" } },
                        "location": { "$ref": "#/components/schemas/Location" },
                        "preferences": { "$ref": "#/components/schemas/Preference" },
                        "photos": { "type": "array", "items": { "$ref": "#/components/schemas/UserPhoto" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Profile not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update user profile (partial update, all fields optional)",
        "tags": ["Profile"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone_number": { "type": "string" },
                  "full_name": { "type": "string" },
                  "age": { "type": "integer" },
                  "gender": { "type": "string", "enum": ["male", "female", "other"] },
                  "city": { "type": "string" },
                  "bio": { "type": "string" },
                  "language": { "type": "string" },
                  "current_step": { "type": "integer", "description": "Current onboarding step (1-7)" },
                  "interests": { "type": "array", "items": { "type": "integer" } },
                  "interested_in": { "type": "string", "enum": ["male", "female", "other", "all"] },
                  "min_age": { "type": "integer" },
                  "max_age": { "type": "integer" },
                  "min_height": { "type": "integer" },
                  "max_height": { "type": "integer" },
                  "max_distance_km": { "type": "integer" },
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
      "/api/interests": {
        "get": {
          "summary": "Get all interests (with icon support)",
          "tags": ["Interests"],
          "responses": {
            "200": {
              "description": "Interests fetched",
              "content": {
                "application/json": {
