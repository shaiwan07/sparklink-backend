{
  "openapi": "3.0.0",
  "info": {
    "title": "Sparklink Dating API",
    "version": "1.0.0",
    "description": "API documentation for Sparklink Dating app."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
