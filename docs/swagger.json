      "/api/matches/potential": {
        "get": {
          "summary": "Get potential matches for user",
          "tags": ["Matches"],
          "security": [{ "bearerAuth": [] }],
          "responses": {
            "200": {
              "description": "Potential matches fetched",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "status": { "type": "boolean" },
                      "message": { "type": "string" },
                      "data": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "user": { "$ref": "#/components/schemas/User" },
                            "interests": { "type": "array", "items": { "$ref": "#/components/schemas/Interest" } },
                            "location": { "$ref": "#/components/schemas/Location" },
                            "preferences": { "$ref": "#/components/schemas/Preference" },
                            "photos": { "type": "array", "items": { "$ref": "#/components/schemas/UserPhoto" } }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "500": {
              "description": "Server error",
